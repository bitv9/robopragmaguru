**src/components/Hero.astro**

---

import settings from "../data/settings.json";
import posts from "../data/posts.json";

## const featured = posts.find((post) => post.featured) ?? posts[0];

```
<section class="hero">

  <div class="container">

<div class="hero-grid">

  <div class="hero-content">

    <span class="hero-badge">
      Featured Article
    </span>

    <h1>
      {settings.homepage.heroTitle}
    </h1>

    <p>
      {settings.homepage.heroDescription}
    </p>

    <div class="hero-buttons">

      <a
        href={settings.homepage.heroButtonLink}
        class="btn btn-primary"
      >
        {settings.homepage.heroButtonText}
      </a>

      <a
        href={`/posts/${featured.slug}`}
        class="btn btn-outline"
      >
        Read Featured
      </a>

    </div>

  </div>

  <div class="hero-card">

    <img
      src={featured.thumbnail}
      alt={featured.title}
      loading="lazy"
    />

    <div class="hero-card-content">

      <span class="hero-category">
        {featured.category}
      </span>

      <h2>
        <a href={`/posts/${featured.slug}`}>
          {featured.title}
        </a>
      </h2>

      <p>
        {featured.excerpt}
      </p>

      <div class="hero-meta">

        <span>{featured.author}</span>

        <span>•</span>

        <span>{featured.date}</span>

        <span>•</span>

        <span>{featured.readingTime}</span>

      </div>

    </div>

  </div>

</div>


  </div>

</section>

<style>

.hero{
  padding:80px 0;
  background:linear-gradient(180deg,#f8fafc,#ffffff);
}

.hero-grid{
  display:grid;
  grid-template-columns:1.1fr .9fr;
  gap:3rem;
  align-items:center;
}

.hero-badge{
  display:inline-block;
  padding:.45rem .9rem;
  margin-bottom:1rem;
  border-radius:999px;
  background:#dbeafe;
  color:#2563eb;
  font-size:.85rem;
  font-weight:600;
}

.hero h1{
  font-size:clamp(2.5rem,5vw,4rem);
  line-height:1.15;
  margin-bottom:1.5rem;
}

.hero p{
  color:#64748b;
  font-size:1.05rem;
  margin-bottom:2rem;
}

.hero-buttons{
  display:flex;
  gap:1rem;
  flex-wrap:wrap;
}

.btn{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:.9rem 1.4rem;
  border-radius:10px;
  font-weight:600;
  transition:.25s;
}

.btn-primary{
  background:#2563eb;
  color:#fff;
}

.btn-primary:hover{
  background:#1d4ed8;
}

.btn-outline{
  border:2px solid #2563eb;
  color:#2563eb;
}

.btn-outline:hover{
  background:#2563eb;
  color:#fff;
}

.hero-card{
  background:#fff;
  border-radius:16px;
  overflow:hidden;
  box-shadow:0 15px 45px rgba(0,0,0,.08);
}

.hero-card img{
  width:100%;
  height:280px;
  object-fit:cover;
}

.hero-card-content{
  padding:1.5rem;
}

.hero-category{
  display:inline-block;
  margin-bottom:.75rem;
  color:#2563eb;
  font-size:.85rem;
  font-weight:700;
}

.hero-card h2{
  margin-bottom:.8rem;
  font-size:1.5rem;
  line-height:1.3;
}

.hero-card h2 a:hover{
  color:#2563eb;
}

.hero-card p{
  margin-bottom:1.2rem;
}

.hero-meta{
  display:flex;
  gap:.6rem;
  flex-wrap:wrap;
  color:#94a3b8;
  font-size:.9rem;
}

@media(max-width:992px){

.hero-grid{
  grid-template-columns:1fr;
}

.hero-card img{
  height:240px;
}

}

@media(max-width:768px){

.hero{
  padding:60px 0;
}

.hero h1{
  font-size:2.2rem;
}

.hero-buttons{
  flex-direction:column;
}

.btn{
  width:100%;
}

}

</style>
