---

import menu from "../data/menu.json";

const mainMenu = menu.filter((item) => item.id);
```
<nav class="navbar">

  <div class="container">


<button
  class="navbar-toggle"
  type="button"
  aria-label="Toggle Navigation"
>
  ☰
</button>

<ul class="navbar-menu">

  {
    mainMenu.map((item) => (

      <li class={`navbar-item ${item.children?.length ? "has-dropdown" : ""}`}>

        <a
          href={item.url}
          target={item.target}
        >
          {item.label}
        </a>

        {
          item.children?.length > 0 && (

            <ul class="navbar-dropdown">

              {
                item.children.map((child) => (

                  <li>
                    <a href={child.url}>
                      {child.label}
                    </a>
                  </li>

                ))
              }

            </ul>

          )
        }

      </li>

    ))
  }

</ul>


  </div>

</nav>

<script>

document.addEventListener("DOMContentLoaded",()=>{

  const toggle=document.querySelector(".navbar-toggle");
  const menu=document.querySelector(".navbar-menu");

  toggle?.addEventListener("click",()=>{
      menu?.classList.toggle("active");
  });

});

</script>

<style>

.navbar{
  background:#ffffff;
  border-bottom:1px solid #e5e7eb;
}

.navbar>.container{
  display:flex;
  align-items:center;
  justify-content:space-between;
}

.navbar-toggle{
  display:none;
  width:44px;
  height:44px;
  border:none;
  background:none;
  cursor:pointer;
  font-size:1.3rem;
}

.navbar-menu{
  display:flex;
  align-items:center;
  gap:2rem;
  list-style:none;
  margin:0;
  padding:0;
}

.navbar-item{
  position:relative;
}

.navbar-item>a{
  display:flex;
  align-items:center;
  height:60px;
  font-weight:600;
  color:#334155;
  transition:.25s;
}

.navbar-item>a:hover{
  color:#2563eb;
}

.navbar-dropdown{
  position:absolute;
  left:0;
  top:100%;
  min-width:220px;
  background:#fff;
  border:1px solid #e5e7eb;
  border-radius:10px;
  box-shadow:0 15px 35px rgba(0,0,0,.08);
  padding:.5rem 0;
  list-style:none;
  display:none;
  z-index:999;
}

.navbar-dropdown li{
  width:100%;
}

.navbar-dropdown a{
  display:block;
  padding:.75rem 1rem;
  color:#475569;
  transition:.25s;
}

.navbar-dropdown a:hover{
  background:#f8fafc;
  color:#2563eb;
}

.has-dropdown:hover>.navbar-dropdown{
  display:block;
}

@media(max-width:768px){

  .navbar-toggle{
    display:block;
  }

  .navbar-menu{
    display:none;
    position:absolute;
    left:0;
    top:100%;
    width:100%;
    background:#fff;
    flex-direction:column;
    align-items:flex-start;
    gap:0;
    border-top:1px solid #e5e7eb;
    box-shadow:0 10px 25px rgba(0,0,0,.06);
  }

  .navbar-menu.active{
    display:flex;
  }

  .navbar-item{
    width:100%;
  }

  .navbar-item>a{
    width:100%;
    height:auto;
    padding:1rem 1.25rem;
  }

  .navbar-dropdown{
    position:static;
    display:block;
    border:none;
    border-radius:0;
    box-shadow:none;
    background:#f8fafc;
    width:100%;
    padding:0;
  }

  .navbar-dropdown a{
    padding:.75rem 2rem;
  }

} 

</style>
