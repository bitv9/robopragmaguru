
---

import settings from "../data/settings.json";
import menu from "../data/menu.json";

const mainMenu = menu.filter((item) => item.id);

```
<header class="site-header">

  <div class="container">

<div class="header-inner">

  <a href="/" class="logo">
    {settings.site.name}
  </a>

  <nav class="nav">

    <ul class="nav-menu">

      {
        mainMenu.map((item) => (

          <li class={`nav-item ${item.children?.length ? "has-dropdown" : ""}`}>

            <a
              href={item.url}
              target={item.target}
            >
              {item.label}
            </a>

            {
              item.children?.length > 0 && (

                <ul class="dropdown">

                  {
                    item.children.map((child) => (

                      <li>
                        <a href={child.url}>
                          {child.label}
                        </a>
                      </li>

                    ))
                  }

                </ul>

              )
            }

          </li>

        ))
      }

    </ul>

  </nav>

  <div class="header-actions">

    <button
      class="search-toggle"
      type="button"
      aria-label="Search"
    >
      🔍
    </button>

    <button
      class="menu-toggle"
      type="button"
      aria-label="Open Menu"
    >
      ☰
    </button>

  </div>

</div>


  </div>

</header>

<script>
document.addEventListener("DOMContentLoaded", () => {

  const menuToggle = document.querySelector(".menu-toggle");
  const nav = document.querySelector(".nav");

  if (menuToggle && nav) {
    menuToggle.addEventListener("click", () => {
      nav.classList.toggle("active");
    });
  }

  document.querySelectorAll(".has-dropdown").forEach((item) => {

    item.addEventListener("mouseenter", () => {
      item.classList.add("open");
    });

    item.addEventListener("mouseleave", () => {
      item.classList.remove("open");
    });

  });

});
</script>

<style>
.site-header{
  position:sticky;
  top:0;
  left:0;
  z-index:999;
  background:#fff;
  border-bottom:1px solid #e5e7eb;
}

.header-inner{
  height:70px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:2rem;
}

.logo{
  font-size:1.5rem;
  font-weight:700;
  color:var(--primary);
}

.nav{
  display:flex;
}

.nav-menu{
  display:flex;
  align-items:center;
  gap:1.5rem;
  list-style:none;
  margin:0;
  padding:0;
}

.nav-item{
  position:relative;
}

.nav-item>a{
  display:block;
  padding:1rem 0;
  font-weight:600;
}

.nav-item>a:hover{
  color:var(--primary);
}

.dropdown{
  position:absolute;
  top:100%;
  left:0;
  min-width:220px;
  background:#fff;
  border:1px solid #eee;
  border-radius:8px;
  box-shadow:0 10px 30px rgba(0,0,0,.08);
  display:none;
  padding:.5rem 0;
  z-index:99;
}

.open>.dropdown{
  display:block;
}

.dropdown li{
  list-style:none;
}

.dropdown a{
  display:block;
  padding:.7rem 1rem;
}

.dropdown a:hover{
  background:#f5f5f5;
}

.header-actions{
  display:flex;
  gap:.75rem;
}

.header-actions button{
  width:42px;
  height:42px;
  border:1px solid #ddd;
  border-radius:8px;
  cursor:pointer;
  background:#fff;
}

.menu-toggle{
  display:none;
}

@media(max-width:768px){

  .menu-toggle{
    display:block;
  }

  .nav{
    position:absolute;
    top:70px;
    left:0;
    width:100%;
    background:#fff;
    border-top:1px solid #eee;
    display:none;
  }

  .nav.active{
    display:block;
  }

  .nav-menu{
    flex-direction:column;
    align-items:flex-start;
    gap:0;
  }

  .nav-item{
    width:100%;
  }

  .nav-item>a{
    padding:1rem;
    width:100%;
  }

  .dropdown{
    position:static;
    display:block;
    border:none;
    box-shadow:none;
    padding-left:1rem;
  }

}
</style>
