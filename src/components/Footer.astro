
---

import settings from "../data/settings.json";
import menu from "../data/menu.json";

const footerMenu =
menu.find((item) => item.footer)?.footer ?? [];
-----------------------------------------------

<footer class="site-footer">
  <div class="container">


<div class="footer-grid">

  <div class="footer-widget">
    <a href="/" class="footer-logo">
      {settings.site.name}
    </a>

    <p class="footer-description">
      {settings.footer.footerDescription}
    </p>

    <div class="footer-social">

      <a
        href={settings.social.facebook}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Facebook"
      >
        Facebook
      </a>

      <a
        href={settings.social.twitter}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Twitter"
      >
        Twitter
      </a>

      <a
        href={settings.social.instagram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
      >
        Instagram
      </a>

      <a
        href={settings.social.youtube}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="YouTube"
      >
        YouTube
      </a>

      <a
        href={settings.social.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
      >
        GitHub
      </a>

    </div>
  </div>

  <div class="footer-widget">
    <h3>Quick Links</h3>

    <ul class="footer-links">
      {
        footerMenu.map((item) => (
          <li>
            <a href={item.url}>
              {item.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="footer-widget">
    <h3>Contact</h3>

    <ul class="footer-contact">
      <li>
        <strong>Email</strong><br />
        <a href={`mailto:${settings.site.email}`}>
          {settings.site.email}
        </a>
      </li>

      <li>
        <strong>Phone</strong><br />
        <a href={`tel:${settings.site.phone.replace(/\s+/g, "")}`}>
          {settings.site.phone}
        </a>
      </li>

      <li>
        <strong>Address</strong><br />
        {settings.site.address}
      </li>
    </ul>
  </div>

</div>

<div class="footer-bottom">

  <p>{settings.footer.copyright}</p>

  <p>
    {settings.footer.madeWith}
  </p>

</div>


  </div>
</footer>
