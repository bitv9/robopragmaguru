---
import MainLayout from "../layouts/MainLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
---

<MainLayout title="Search - Ai Mr Dennis">

  <div class="search-page">
    <h1>Search Articles</h1>

    <input id="searchInput" placeholder="Cari artikel..." />

    <p id="emptyState">Ketik untuk mencari artikel...</p>

    <div id="results">
      {posts.map((post) => (
        <a class="item" href={`/blog/${post.slug}/`}>
          <h3>{post.data.title}</h3>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </div>

</MainLayout>

<script is:inline>
  const input = document.getElementById("searchInput");
  const items = document.querySelectorAll(".item");
  const emptyState = document.getElementById("emptyState");

  // default: sembunyikan semua item
  items.forEach((item) => item.style.display = "none");

  input.addEventListener("input", (e) => {
    const value = e.target.value.trim().toLowerCase();

    let hasResult = false;

    items.forEach((item) => {
      const text = item.innerText.toLowerCase();

      const match = value !== "" && text.includes(value);

      item.style.display = match ? "block" : "none";

      if (match) hasResult = true;
    });

    // empty state logic
    if (value === "") {
      emptyState.style.display = "block";
      items.forEach((item) => item.style.display = "none");
    } else {
      emptyState.style.display = hasResult ? "none" : "block";
    }
  });
</script>

<style>
.search-page{
  max-width: 800px;
  margin: 80px auto;
  padding: 0 20px;
}

.search-page h1{
  font-size: 36px;
  margin-bottom: 20px;
}

#searchInput{
  width: 100%;
  padding: 14px;
  border: 1px solid var(--border, #ddd);
  border-radius: 12px;
  font-size: 16px;
  outline: none;
  margin-bottom: 20px;
}

#emptyState{
  opacity: 0.6;
  margin-bottom: 20px;
}

#results{
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.item{
  display: block;
  padding: 16px;
  border: 1px solid var(--border, #eee);
  border-radius: 14px;
  text-decoration: none;
  color: inherit;
  transition: 0.2s;
}

.item:hover{
  transform: translateY(-2px);
}

.item h3{
  margin: 0 0 6px;
  font-size: 18px;
}

.item p{
  margin: 0;
  opacity: 0.7;
  font-size: 14px;
}
</style>
