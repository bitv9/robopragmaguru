---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE } from '../lib/site';

const pageTitle =
  'About Ai Mr Dennis - AI, SEO & Digital Modern';

const pageDescription =
  'Tentang Ai Mr Dennis, platform digital modern yang fokus pada AI, SEO, automation, teknologi, tools online dan pengembangan website modern ultra cepat.';
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={`${SITE.url()}/about`}
>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">

        <div class="hero-left">

          <div class="hero-tag">
            ABOUT AI MR DENNIS
          </div>

          <h1>
            Membangun Ecosystem Digital Modern
          </h1>

          <p>
            Ai Mr Dennis adalah platform digital yang berfokus pada AI, SEO,
            automation, tools online, website modern dan teknologi internet
            masa kini dengan performa cepat, clean dan mobile first.
          </p>

          <div class="hero-btns">
            <a
              href="https://aimrdennis.com"
              class="btn btn-primary"
            >
              Official Website
            </a>

            <a
              href="https://news.aimrdennis.com"
              class="btn btn-secondary"
            >
              Latest Articles
            </a>
          </div>

        </div>

        <div class="hero-right">

          <div class="hero-card">
            <div class="hero-badge">
              TECHNOLOGY
            </div>

            <h3>
              AI & Automation
            </h3>

            <p>
              Fokus pada teknologi AI modern, automation system dan workflow digital.
            </p>
          </div>

          <div class="hero-card">
            <div class="hero-badge">
              PERFORMANCE
            </div>

            <h3>
              Fast & Clean
            </h3>

            <p>
              Website modern ultra ringan dengan design minimal dan SEO optimized.
            </p>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section">
    <div class="container">

      <h2 class="section-title">
        Siapa Ai Mr Dennis?
      </h2>

      <p class="section-desc">
        Platform digital modern untuk teknologi, AI dan internet ecosystem.
      </p>

      <div class="features">

        <div class="feature-card">
          <h3>AI Technology</h3>

          <p>
            Mengembangkan dan membahas berbagai teknologi AI modern,
            automation dan smart digital system.
          </p>
        </div>

        <div class="feature-card">
          <h3>SEO & Website</h3>

          <p>
            Fokus pada website cepat, SEO modern, performa tinggi dan mobile first.
          </p>
        </div>

        <div class="feature-card">
          <h3>Digital Tools</h3>

          <p>
            Membangun tools online dan utility digital untuk kebutuhan modern.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- MISSION -->
  <section class="section">
    <div class="container">

      <h2 class="section-title">
        Mission
      </h2>

      <p class="section-desc">
        Membuat teknologi modern lebih cepat, ringan dan mudah diakses.
      </p>

      <div class="pricing">

        <div class="price-card">
          <h3>Modern Design</h3>

          <p>
            Interface clean dan minimal untuk pengalaman pengguna yang nyaman.
          </p>
        </div>

        <div class="price-card">
          <h3>High Performance</h3>

          <p>
            Fokus pada kecepatan loading, SEO dan performa website modern.
          </p>
        </div>

        <div class="price-card">
          <h3>Future Ready</h3>

          <p>
            Mengikuti perkembangan AI, teknologi dan digital ecosystem terbaru.
          </p>
        </div>

      </div>

    </div>
  </section>

  <!-- WHY -->
  <section class="section">
    <div class="container">

      <h2 class="section-title">
        Why Choose Ai Mr Dennis?
      </h2>

      <p class="section-desc">
        Dibangun untuk internet modern dengan fokus performa dan kualitas.
      </p>

      <div class="faq-item">
        <div class="faq-question">
          <span>Apakah website sudah SEO optimized?</span>
          <div class="faq-icon"></div>
        </div>

        <div class="faq-answer">
          <p>
            Ya, seluruh struktur dibangun mobile first, clean dan SEO friendly.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">
          <span>Apakah fokus pada AI dan teknologi modern?</span>
          <div class="faq-icon"></div>
        </div>

        <div class="faq-answer">
          <p>
            Ya, Ai Mr Dennis fokus pada AI, automation, internet tools dan teknologi modern.
          </p>
        </div>
      </div>

      <div class="faq-item">
        <div class="faq-question">
          <span>Apakah tersedia artikel dan tutorial?</span>
          <div class="faq-icon"></div>
        </div>

        <div class="faq-answer">
          <p>
            Tersedia berbagai artikel, tutorial dan insight digital terbaru.
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">

      <h2>
        Explore Modern Digital Technology
      </h2>

      <p>
        AI, SEO, automation, tools digital dan website modern dalam satu ecosystem.
      </p>

      <a
        href="https://aimrdennis.com"
        class="btn btn-primary"
      >
        Visit Website
      </a>

    </div>
  </section>

</MainLayout>
