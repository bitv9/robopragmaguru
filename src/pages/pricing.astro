---
import MainLayout from '../layouts/MainLayout.astro';
import { SITE } from '../lib/site';

const pageTitle = 'Pricing - Ai Mr Dennis';
const pageDescription =
  'Paket harga layanan Ai Mr Dennis untuk website, SEO, AI tools, automation, dan digital growth modern.';
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={SITE.url()}
>

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">

        <div class="hero-left">

          <div class="hero-tag">
            PRICING PLAN
          </div>

          <h1>
            Simple & Transparent Pricing
          </h1>

          <p>
            Pilih paket sesuai kebutuhan bisnis kamu. Mulai dari website landing, SEO, hingga sistem digital automation.
          </p>

          <div class="hero-btns">
            <a href="https://aimrdennis.com" class="btn btn-primary">
              Get Started
            </a>

            <a href="https://news.aimrdennis.com" class="btn btn-secondary">
              Learn More
            </a>
          </div>

        </div>

        <div class="hero-right">

          <div class="hero-card">
            <div class="hero-badge">FAST SETUP</div>
            <h3>Instant Deployment</h3>
            <p>Website siap online dengan setup cepat dan clean.</p>
          </div>

          <div class="hero-card">
            <div class="hero-badge">SEO READY</div>
            <h3>Search Optimized</h3>
            <p>Struktur SEO modern untuk Google indexing lebih cepat.</p>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="section">
    <div class="container">

      <h2 class="section-title">
        Pricing Plans
      </h2>

      <p class="section-desc">
        Pilih paket terbaik untuk kebutuhan digital kamu.
      </p>

      <div class="pricing">

        <!-- BASIC -->
        <div class="price-card">
          <h3>Basic</h3>

          <p class="price">Rp99K <span>/bulan</span></p>

          <p>
            Cocok untuk personal website atau landing page sederhana.
          </p>

          <ul>
            <li>✔ 1 Landing Page</li>
            <li>✔ Basic SEO Setup</li>
            <li>✔ Mobile Responsive</li>
            <li>✔ Fast Loading</li>
          </ul>

          <a href="#" class="btn">
            Choose Basic
          </a>
        </div>

        <!-- PRO -->
        <div class="price-card popular">
          <div class="badge">Most Popular</div>

          <h3>Pro</h3>

          <p class="price">Rp299K <span>/bulan</span></p>

          <p>
            Untuk bisnis yang ingin growth & visibility lebih tinggi.
          </p>

          <ul>
            <li>✔ Multi Page Website</li>
            <li>✔ Advanced SEO</li>
            <li>✔ Blog Setup (Astro)</li>
            <li>✔ Priority Support</li>
          </ul>

          <a href="#" class="btn btn-primary">
            Choose Pro
          </a>
        </div>

        <!-- BUSINESS -->
        <div class="price-card">
          <h3>Business</h3>

          <p class="price">Rp599K <span>/bulan</span></p>

          <p>
            Full system untuk bisnis, brand, dan automation skala besar.
          </p>

          <ul>
            <li>✔ Unlimited Pages</li>
            <li>✔ Full SEO Optimization</li>
            <li>✔ AI Content System</li>
            <li>✔ Dedicated Support</li>
          </ul>

          <a href="#" class="btn">
            Choose Business
          </a>
        </div>

      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">

      <h2>
        Ready to Build Your Digital Presence?
      </h2>

      <p>
        Mulai dari sekarang dan bangun sistem digital modern untuk bisnis kamu.
      </p>

      <a href="https://aimrdennis.com" class="btn btn-primary">
        Start Now
      </a>

    </div>
  </section>

</MainLayout>
