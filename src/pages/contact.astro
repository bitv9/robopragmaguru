---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Contact - Ai Mr Dennis"
  description="Hubungi Ai Mr Dennis untuk konsultasi digital growth, SEO strategy, dan website optimization."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <span class="badge">Contact Ai Mr Dennis</span>

        <h1>
          Mari Diskusikan Growth Bisnis Digital Anda
        </h1>

        <p>
          Konsultasikan kebutuhan SEO, website optimization,
          content strategy, dan digital growth bersama Ai Mr Dennis.
        </p>

        <div class="contact-list">
          <div class="contact-item">
            <strong>Email</strong>
            <p>hello@aimrdennis.com</p>
          </div>

          <div class="contact-item">
            <strong>WhatsApp</strong>
            <p>+62 812-3456-7890</p>
          </div>

          <div class="contact-item">
            <strong>Location</strong>
            <p>Indonesia</p>
          </div>
        </div>
      </div>

      <div class="card form-card">
        <h2>Konsultasi Gratis</h2>

        <p>
          Isi form berikut dan tim Ai Mr Dennis akan
          menghubungi Anda secepat mungkin.
        </p>

        <form class="contact-form">
          <div class="form-group">
            <label>Nama</label>
            <input
              type="text"
              placeholder="Nama lengkap"
            />
          </div>

          <div class="form-group">
            <label>Email</label>
            <input
              type="email"
              placeholder="email@domain.com"
            />
          </div>

          <div class="form-group">
            <label>Website</label>
            <input
              type="text"
              placeholder="https://websiteanda.com"
            />
          </div>

          <div class="form-group">
            <label>Kebutuhan</label>

            <textarea
              rows="5"
              placeholder="Ceritakan kebutuhan bisnis Anda..."
            ></textarea>
          </div>

          <button type="submit" class="btn btn-primary">
            Kirim Konsultasi
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section>
    <div class="container">
      <div class="section-title">
        <h2>Layanan Digital Growth</h2>

        <p>
          Solusi modern untuk membantu bisnis meningkatkan
          visibility, authority, dan conversion.
        </p>
      </div>

      <div class="service-grid">
        <div class="service-item">
          <h3>SEO Strategy</h3>

          <p>
            Audit SEO, keyword research,
            dan growth roadmap berbasis data.
          </p>
        </div>

        <div class="service-item">
          <h3>Technical Optimization</h3>

          <p>
            Optimasi technical SEO, indexing,
            performance, dan website structure.
          </p>
        </div>

        <div class="service-item">
          <h3>Content Strategy</h3>

          <p>
            Strategi topical authority dan
            content cluster untuk growth jangka panjang.
          </p>
        </div>

        <div class="service-item">
          <h3>Conversion Optimization</h3>

          <p>
            Optimasi UX dan conversion
            agar traffic menghasilkan leads.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section-dark">
    <div class="container">
      <div class="section-title">
        <h2>Bagaimana Proses Konsultasi?</h2>
      </div>

      <div class="process-grid">
        <div class="process-item">
          <div class="process-number">1</div>

          <h3>Diskusi Awal</h3>

          <p>
            Memahami kondisi website,
            target market, dan goals bisnis Anda.
          </p>
        </div>

        <div class="process-item">
          <div class="process-number">2</div>

          <h3>Audit & Analysis</h3>

          <p>
            Analisis technical SEO,
            content structure, dan kompetitor.
          </p>
        </div>

        <div class="process-item">
          <div class="process-number">3</div>

          <h3>Strategy Planning</h3>

          <p>
            Menyusun roadmap growth
            dan strategi optimasi yang sesuai.
          </p>
        </div>

        <div class="process-item">
          <div class="process-number">4</div>

          <h3>Execution</h3>

          <p>
            Implementasi strategi dan
            monitoring perkembangan website.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section>
    <div class="container">
      <div class="section-title">
        <h2>Pertanyaan Umum</h2>
      </div>

      <div class="faq-grid">
        <div class="faq-item">
          <h3>Apakah konsultasi gratis?</h3>

          <p>
            Ya, konsultasi awal gratis
            untuk memahami kebutuhan bisnis Anda.
          </p>
        </div>

        <div class="faq-item">
          <h3>Berapa lama proses SEO?</h3>

          <p>
            Umumnya membutuhkan 3–6 bulan
            tergantung tingkat kompetisi niche.
          </p>
        </div>

        <div class="faq-item">
          <h3>Apakah menerima bisnis kecil?</h3>

          <p>
            Ya, Ai Mr Dennis membantu UMKM,
            startup, hingga perusahaan besar.
          </p>
        </div>

        <div class="faq-item">
          <h3>Apakah ada reporting?</h3>

          <p>
            Ya, tersedia reporting rutin
            untuk keyword, traffic, dan growth progress.
          </p>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  :global(:root) {
    --bg: #0f172a;
    --card: #111827;
    --soft: #1e293b;
    --border: rgba(255,255,255,.08);
    --text: #f8fafc;
    --muted: #94a3b8;
    --primary: #3b82f6;
    --primary-hover: #2563eb;
    --radius: 24px;
    --container: 1180px;
  }

  section {
    padding: 90px 20px;
  }

  .container {
    width: 100%;
    max-width: var(--container);
    margin: auto;
  }

  .section-dark {
    background: rgba(255,255,255,.02);
  }

  .hero {
    padding-top: 120px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: repeat(2,1fr);
    gap: 40px;
    align-items: center;
  }

  .badge {
    display: inline-flex;
    padding: 10px 18px;
    border-radius: 999px;
    background: rgba(59,130,246,.12);
    border: 1px solid rgba(59,130,246,.25);
    color: #93c5fd;
    font-size: 14px;
    font-weight: 700;
  }

  .hero h1 {
    font-size: clamp(42px, 7vw, 68px);
    line-height: 1.05;
    margin: 20px 0;
  }

  .hero p {
    color: var(--muted);
    font-size: 18px;
    line-height: 1.8;
  }

  .contact-list {
    display: grid;
    gap: 18px;
    margin-top: 40px;
  }

  .contact-item {
    padding: 24px;
    border-radius: 20px;
    background: rgba(255,255,255,.03);
    border: 1px solid var(--border);
  }

  .contact-item strong {
    display: block;
    margin-bottom: 8px;
  }

  .contact-item p {
    color: var(--muted);
    margin: 0;
  }

  .card,
  .service-item,
  .process-item,
  .faq-item {
    background: rgba(255,255,255,.03);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .card,
  .service-item,
  .process-item,
  .faq-item {
    padding: 32px;
  }

  .form-card h2 {
    margin-bottom: 12px;
  }

  .contact-form {
    margin-top: 30px;
    display: grid;
    gap: 20px;
  }

  .form-group {
    display: grid;
    gap: 10px;
  }

  label {
    font-weight: 600;
  }

  input,
  textarea {
    width: 100%;
    padding: 16px 18px;
    border-radius: 14px;
    border: 1px solid rgba(255,255,255,.08);
    background: rgba(255,255,255,.03);
    color: white;
    outline: none;
    font-size: 15px;
  }

  input:focus,
  textarea:focus {
    border-color: rgba(59,130,246,.5);
  }

  textarea {
    resize: vertical;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 28px;
    border-radius: 14px;
    text-decoration: none;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: .3s ease;
  }

  .btn-primary {
    background: var(--primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--primary-hover);
    transform: translateY(-2px);
  }

  .section-title {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 60px;
  }

  .section-title h2 {
    font-size: clamp(32px, 5vw, 48px);
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .section-title p {
    color: var(--muted);
    line-height: 1.8;
  }

  .service-grid,
  .process-grid,
  .faq-grid {
    display: grid;
    gap: 24px;
  }

  .service-grid,
  .process-grid {
    grid-template-columns: repeat(2,1fr);
  }

  .faq-grid {
    grid-template-columns: repeat(2,1fr);
  }

  .service-item h3,
  .process-item h3,
  .faq-item h3 {
    margin-bottom: 14px;
  }

  .service-item p,
  .process-item p,
  .faq-item p {
    color: var(--muted);
    line-height: 1.8;
  }

  .process-number {
    width: 56px;
    height: 56px;
    border-radius: 16px;
    background: var(--primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    margin-bottom: 24px;
  }

  @media (max-width: 980px) {
    .hero-grid,
    .service-grid,
    .process-grid,
    .faq-grid {
      grid-template-columns: 1fr;
    }

    section {
      padding: 70px 20px;
    }

    .hero {
      padding-top: 90px;
    }
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 40px;
    }

    .card,
    .service-item,
    .process-item,
    .faq-item {
      padding: 24px;
    }

    .btn {
      width: 100%;
    }
  }
</style>
