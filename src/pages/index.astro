
---

import BaseLayout from "../layouts/BaseLayout.astro";

import Hero from "../components/Hero.astro";

import posts from "../data/posts.json";

const featuredPosts = posts.filter(post => post.featured);

const latestPosts = posts.slice(0, 10);
---
<BaseLayout
title="Home"
description="Welcome to Astro Blogger."

>

<Hero />

<section class="section">

  <div class="container">


<div class="section-heading">

  <h2>Featured Posts</h2>

  <p>Highlighted articles selected for readers.</p>

</div>

<div class="featured-grid">

  {

    featuredPosts.map(post => (

    <article class="post-card">

      <a
        href={`/posts/${post.slug}`}
        class="post-image"
      >

        <img
          src={post.thumbnail}
          alt={post.title}
          loading="lazy"
        />

      </a>

      <div class="post-content">

        <span class="post-category">

          {post.category}

        </span>

        <h3>

          <a href={`/posts/${post.slug}`}>

            {post.title}

          </a>

        </h3>

        <p>

          {post.excerpt}

        </p>

        <div class="post-meta">

          <span>{post.author}</span>

          <span>•</span>

          <span>{post.date}</span>

          <span>•</span>

          <span>{post.readingTime}</span>

        </div>

      </div>

    </article>

    ))

  }

</div>


  </div>

</section>

<section class="section section-light">

  <div class="container">


<div class="section-heading">

  <h2>Latest Articles</h2>

  <p>Recent posts from the blog.</p>

</div>

<div class="posts-grid">

  {

    latestPosts.map(post => (

    <article class="card">

      <img
        src={post.thumbnail}
        alt={post.title}
        loading="lazy"
      />

      <div class="card-body">

        <span class="category">

          {post.category}

        </span>

        <h3>

          <a href={`/posts/${post.slug}`}>

            {post.title}

          </a>

        </h3>

        <p>

          {post.excerpt}

        </p>

        <div class="meta">

          <span>{post.author}</span>

          <span>{post.date}</span>

        </div>

        <a
          href={`/posts/${post.slug}`}
          class="read-more"
        >

          Read More →

        </a>

      </div>

    </article>

    ))

  }

</div>


  </div>

</section>

</BaseLayout>

<style>

.section{

  padding:70px 0;

}

.section-light{

  background:#f8fafc;

}

.section-heading{

  text-align:center;

  margin-bottom:45px;

}

.section-heading h2{

  font-size:2rem;

  margin-bottom:.5rem;

}

.section-heading p{

  color:#64748b;

}

.featured-grid{

  display:grid;

  grid-template-columns:repeat(2,1fr);

  gap:2rem;

}

.post-card{

  background:#fff;

  border-radius:14px;

  overflow:hidden;

  box-shadow:0 10px 30px rgba(0,0,0,.08);

}

.post-image img{

  width:100%;

  height:280px;

  object-fit:cover;

}

.post-content{

  padding:1.5rem;

}

.post-category{

  color:#2563eb;

  font-size:.85rem;

  font-weight:700;

}

.post-content h3{

  margin:12px 0;

}

.post-content h3 a:hover{

  color:#2563eb;

}

.post-content p{

  color:#64748b;

}

.post-meta{

  display:flex;

  gap:.6rem;

  margin-top:1rem;

  color:#94a3b8;

  font-size:.9rem;

}

.posts-grid{

  display:grid;

  grid-template-columns:repeat(3,1fr);

  gap:2rem;

}

.card{

  background:#fff;

  border-radius:14px;

  overflow:hidden;

  box-shadow:0 8px 25px rgba(0,0,0,.08);

}

.card img{

  width:100%;

  height:220px;

  object-fit:cover;

}

.card-body{

  padding:1.4rem;

}

.category{

  color:#2563eb;

  font-size:.85rem;

  font-weight:700;

}

.card-body h3{

  margin:10px 0;

}

.card-body h3 a:hover{

  color:#2563eb;

}

.card-body p{

  color:#64748b;

  margin-bottom:1rem;

}

.meta{

  display:flex;

  justify-content:space-between;

  font-size:.9rem;

  color:#94a3b8;

  margin-bottom:1rem;

}

.read-more{

  color:#2563eb;

  font-weight:600;

}

.read-more:hover{

  color:#1d4ed8;

}

@media(max-width:992px){

.featured-grid{

grid-template-columns:1fr;

}

.posts-grid{

grid-template-columns:repeat(2,1fr);

}

}

@media(max-width:768px){

.posts-grid{

grid-template-columns:1fr;

}

.post-image img{

height:220px;

}

}

</style>
